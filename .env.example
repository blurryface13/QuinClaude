# QUIN core service
QUIN_HOST=127.0.0.1
QUIN_PORT=7437
QUIN_LOG_LEVEL=INFO
QUIN_LOG_FILE=~/.quin/logs/core.log
QUIN_LOG_FORMAT=text

# LLM provider
# Defaults are aligned with the local JAgent DeepSeek setup.
QUIN_LLM_PROVIDER=deepseek
QUIN_LLM_BASE_URL=https://api.deepseek.com
QUIN_LLM_API_KEY=
QUIN_LLM_MODEL=deepseek-chat

# Optional Anthropic mode:
# QUIN_LLM_PROVIDER=anthropic
# QUIN_LLM_MODEL=claude-sonnet-4-6
# ANTHROPIC_API_KEY=

# Agent loop limits
QUIN_MAX_STEPS=20

# Trace and compaction
QUIN_TRACE_ENABLED=true
QUIN_TRACE_FILE=~/.quin/traces/daemon.jsonl
QUIN_TRACE_INCLUDE_LLM_PAYLOAD=true
QUIN_COMPACT_THRESHOLD=0
QUIN_COMPACT_TOOL_LIMIT=8000
QUIN_COMPACT_TOOL_KEEP=4000
QUIN_PERMISSION_TIMEOUT_S=60
